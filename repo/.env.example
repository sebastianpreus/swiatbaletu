# Sanity — uzyskaj z https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Supabase — uzyskaj z https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth — wygeneruj: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Brevo (newsletter) — uzyskaj z https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_SENDER_EMAIL=newsletter@swiatbaletu.pl

# Newsletter — klucz do autoryzacji wysyłki (wygeneruj dowolny string)
NEWSLETTER_API_KEY=

# URL strony (produkcja)
NEXT_PUBLIC_SITE_URL=https://swiatbaletu.vercel.app
